NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ritusarthi
CLIENT_URLS=http://localhost:5173,https://your-frontend-site.netlify.app

JWT_SECRET=replace_with_a_random_secret_at_least_32_characters_long
JWT_EXPIRES_IN=1d
JWT_ISSUER=ritusarthi-api
JWT_AUDIENCE=ritusarthi-admin

RATE_LIMIT_WINDOW_MINUTES=15
API_RATE_LIMIT_MAX=200
LOGIN_RATE_LIMIT_MAX=5

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_your_razorpay_secret
RAZORPAY_CURRENCY=INR

ADMIN_REGISTRATION_ENABLED=false
ADMIN_REGISTRATION_TOKEN=replace_with_a_one_time_setup_token
ADMIN_NOTIFICATION_EMAIL=admin@example.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=replace_with_smtp_password
SMTP_FROM_EMAIL=mailer@example.com
SMTP_FROM_NAME=Rituu Saarthhii Tours & Travels
SMTP_SECURE=false
